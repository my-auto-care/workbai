# ============================================================
# Workbay AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# All values below are stored as GitHub Actions secrets.
# ============================================================

# --- DigitalOcean API ---
DO_API_TOKEN=

# --- DigitalOcean Spaces (S3-compatible Object Storage) ---
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET_DATA=workbay-data
DO_SPACES_BUCKET_CHECKPOINTS=workbay-checkpoints

# --- Postgres Database ---
# Connection string format: postgres://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Auth0 (Authentication) ---
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- Stripe (Payments) ---
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET=

# --- AssemblyAI (Speech-to-Text) ---
ASSEMBLYAI_API_KEY=

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=

# --- LiveKit (Real-time Voice/Video) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Datadog (Monitoring & Observability) ---
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com

# --- Vercel (Frontend Deployment) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- GitHub ---
GH_TOKEN=

# --- Server IPs ---
ORCHESTRATOR_VPS_IP=167.71.24.70
BACKEND_VPS_IP=167.99.153.77

# --- AI / LLM Services (from ZeptoClaw config) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
